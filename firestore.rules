rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidHouse(data) {
      return data.keys().hasAll(['title', 'price', 'location', 'userId', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.price is number &&
             data.location is string && data.location.size() <= 500 &&
             data.userId == request.auth.uid &&
             data.createdAt is number;
    }

    match /houses/{houseId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidHouse(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.userId) && 
                      isValidHouse(request.resource.data);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    match /userProgress/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
